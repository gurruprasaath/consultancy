# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Docker Compose: mongodb://mongo:27017/food7
# Railway MongoDB plugin: set to the plugin's connection string
MONGODB_URI=mongodb://mongo:27017/food7

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# ── AI ────────────────────────────────────────────────────────────────────────
# Get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Frontend URL (for CORS) ────────────────────────────────────────────────────
# Production: set to your deployed frontend URL e.g. https://food7.up.railway.app
FRONTEND_URL=http://localhost:80

# ── Razorpay Payments ─────────────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── WhatsApp Business Cloud API (optional) ───────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Instagram Graph API (optional) ───────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads/calls
